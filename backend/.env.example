# === Google Sheets (fonte financeira) ===
# Conteúdo COMPLETO do JSON da Service Account em uma linha (string única).
# Compartilhe a planilha como LEITOR com o e-mail da Service Account e remova
# "qualquer um com o link" (a planilha NÃO deve ficar pública — isolamento R-001).
# Os valores REAIS (JSON da SA, e-mail, SHEET_ID) vivem só no `.env` local/no ambiente,
# NUNCA versionados (Princípio IV da constituição).
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
SHEET_ID=<id-da-planilha-de-producao>  # nunca commitar o ID real
SHEET_TAB_SOLICITACOES=Dados Tratados
SHEET_TAB_CADASTRO=Cadastro de Clientes
SHEET_TAB_BASE=base de dados
SHEET_CACHE_TTL=180

# === Supabase (auth + usuários) ===
SUPABASE_URL=https://<projeto>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...   # SÓ no backend, nunca no frontend
SUPABASE_JWT_SECRET=...         # Project Settings > API > JWT Secret

# === HTTP ===
CORS_ORIGINS=http://localhost:3000
